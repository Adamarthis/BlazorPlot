@using BlazorPlot.Web.Services
@inject IJSRuntime JSRuntime
@inject CalculatorState State
@inject ViewportManager Viewport

<div style="position: relative; width: 100%; height: 100%; overflow: hidden;">
    <canvas @ref="_canvasRef" 
            width="800" height="600" 
            style="width: 100%; height: 100%; display: block; cursor: @(_isDragging ? "grabbing" : "crosshair");"
            @onwheel="HandleWheel"
            @onmousedown="OnMouseDown"
            @onmousemove="OnMouseMove"
            @onmouseup="OnMouseUp"
            @onmouseleave="OnMouseUp">
    </canvas>

    @if (_activePoint != null)
    {
        <div style="position: absolute; 
                    left: @(Math.Round(_activePoint.ScreenX - 5))px; 
                    top: @(Math.Round(_activePoint.ScreenY - 5))px; 
                    width: 10px; height: 10px; 
                    background-color: @(_activePoint.Color); 
                    border: 2px solid white; 
                    border-radius: 50%; 
                    pointer-events: none; 
                    box-shadow: 0 0 6px rgba(0,0,0,0.5);
                    z-index: 10;">
        </div>
        
        <div style="position: absolute; 
                    left: @(Math.Round(_activePoint.ScreenX + 15))px; 
                    top: @(Math.Round(_activePoint.ScreenY - 15))px; 
                    background: rgba(25, 25, 25, 0.9); 
                    color: white; 
                    padding: 4px 8px; 
                    border-radius: 4px; 
                    font-family: monospace; 
                    font-size: 13px; 
                    pointer-events: none; 
                    white-space: nowrap; 
                    z-index: 10;
                    @(_activePoint.IsImportant ? "font-weight: bold; border: 1px solid white;" : "")">
            @if (!string.IsNullOrEmpty(_activePoint.Label))
            {
                <span style="color: #FFD700; margin-right: 5px;">@_activePoint.Label:</span>
            }
            @Math.Round(_activePoint.MathX, 3), @Math.Round(_activePoint.MathY, 3)
        </div>
    }
</div>

@code {
    private ElementReference _canvasRef;
    private bool _isReady = false;
    private bool _isZooming = false;
    private CancellationTokenSource? _zoomDebounceCts;

    private class TracePoint
    {
        public double ScreenX { get; set; }
        public double ScreenY { get; set; }
        public double MathX { get; set; }
        public double MathY { get; set; }
        public string Color { get; set; } = "";
        public bool IsImportant { get; set; }
        public string Label { get; set; } = "";
    }

    private TracePoint? _activePoint = null;
    private double _clickStartX;
    private double _clickStartY;

    private async Task HandleWheel(Microsoft.AspNetCore.Components.Web.WheelEventArgs e)
    {
        _isZooming = true;

        double zoomFactor = e.DeltaY > 0 ? 1.05 : 0.95;

        Viewport.UnitsPerPixel *= zoomFactor;
        if (Viewport.UnitsPerPixel < 0.0001) Viewport.UnitsPerPixel = 0.0001;
        if (Viewport.UnitsPerPixel > 100) Viewport.UnitsPerPixel = 100;

        await RenderGraphsAsync();

        _zoomDebounceCts?.Cancel();
        _zoomDebounceCts = new CancellationTokenSource();
        
        try 
        {
            await Task.Delay(200, _zoomDebounceCts.Token);

            _isZooming = false;
            await RenderGraphsAsync();
        }
        catch (TaskCanceledException) {}
    }

    private bool _isDragging = false;
    private double _lastMouseX;
    private double _lastMouseY;

    private void OnMouseDown(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        _isDragging = true;
        _lastMouseX = e.OffsetX;
        _lastMouseY = e.OffsetY;
        _clickStartX = e.OffsetX;
        _clickStartY = e.OffsetY;
    }

    private async Task OnMouseMove(Microsoft.AspNetCore.Components.Web.MouseEventArgs e) 
    {
        if (!_isDragging) return;

        _activePoint = null; 

        double deltaX = e.OffsetX - _lastMouseX;
        double deltaY = e.OffsetY - _lastMouseY;

        _lastMouseX = e.OffsetX;
        _lastMouseY = e.OffsetY;

        Viewport.CenterX -= deltaX * Viewport.UnitsPerPixel;
        Viewport.CenterY += deltaY * Viewport.UnitsPerPixel;

        await RenderGraphsAsync();
    }

    private async void OnMouseUp(Microsoft.AspNetCore.Components.Web.MouseEventArgs e) 
    {
        _isDragging = false;

        double moveDist = Math.Abs(e.OffsetX - _clickStartX) + Math.Abs(e.OffsetY - _clickStartY);
        if (moveDist < 5) 
        {
            FindPointOnClick(e.OffsetX, e.OffsetY);
        }

        await RenderGraphsAsync();
    }

    private void FindPointOnClick(double mousePx, double mousePy)
    {
        double radiusPx = 25;
        TracePoint? bestPoint = null;
        double minScore = double.MaxValue;

        var explicitEqs = State.Equations.Where(eq => eq.IsVisible && !eq.HasError && !eq.IsImplicit && !eq.IsPoint && eq.Function != null).ToList();
        var implicitEqs = State.Equations.Where(eq => eq.IsVisible && !eq.HasError && eq.IsImplicit && eq.Function != null).ToList();

        double xAxisPy = Viewport.MathToScreen(0, 0).py;
        double yAxisPx = Viewport.MathToScreen(0, 0).px;

        for (double px = mousePx - radiusPx; px <= mousePx + radiusPx; px += 1)
        {
            var (mX, _) = Viewport.ScreenToMath(px, 0);

            for (int i = 0; i < explicitEqs.Count; i++)
            {
                var eq1 = explicitEqs[i];
                double mY1 = eq1.Function!.Evaluate(mX);
                var (_, py1) = Viewport.MathToScreen(mX, mY1);

                double distToMouse = Math.Sqrt(Math.Pow(px - mousePx, 2) + Math.Pow(py1 - mousePy, 2));
                if (distToMouse > radiusPx) continue;

                bool isImportant = false;
                string label = "";
                string color = eq1.Color;
                double finalX = mX;
                double finalY = mY1;

                if (Math.Abs(px - yAxisPx) < 4) { finalX = 0; finalY = eq1.Function.Evaluate(0); isImportant = true; label = "Y-Intercept"; }
                else if (Math.Abs(py1 - xAxisPy) < 4) { finalY = 0; isImportant = true; label = "Root"; }
                else 
                {
                    for (int j = i + 1; j < explicitEqs.Count; j++)
                    {
                        var eq2 = explicitEqs[j];
                        double mY2 = eq2.Function!.Evaluate(mX);
                        var (_, py2) = Viewport.MathToScreen(mX, mY2);

                        if (Math.Abs(py1 - py2) < 3) 
                        {
                            isImportant = true; label = "Intersection";
                            color = "#FFFFFF"; 
                            finalY = (mY1 + mY2) / 2.0; 
                            break;
                        }
                    }
                }

                double score = isImportant ? distToMouse * 0.05 : distToMouse;

                if (score < minScore)
                {
                    minScore = score;
                    var (finalPx, finalPy) = Viewport.MathToScreen(finalX, finalY);
                    bestPoint = new TracePoint { ScreenX = finalPx, ScreenY = finalPy, MathX = finalX, MathY = finalY, Color = color, IsImportant = isImportant, Label = label };
                }
            }
        }
        foreach (var eq in implicitEqs)
        {
            int step = 2;
            
            for (double py = mousePy - radiusPx; py <= mousePy + radiusPx; py += step)
            {
                for (double px = mousePx - radiusPx; px <= mousePx + radiusPx; px += step)
                {
                    var (mX1, mY1) = Viewport.ScreenToMath(px, py);
                    var (mX2, _) = Viewport.ScreenToMath(px + step, py);
                    var (_, mY3) = Viewport.ScreenToMath(px, py + step);

                    double v1 = eq.Function!.Evaluate(mX1, mY1);
                    double v2 = eq.Function.Evaluate(mX2, mY1);
                    double v3 = eq.Function.Evaluate(mX1, mY3);

                    if (v1 * v2 <= 0 || v1 * v3 <= 0)
                    {
                        double distToMouse = Math.Sqrt(Math.Pow(px - mousePx, 2) + Math.Pow(py - mousePy, 2));

                        if (distToMouse < minScore)
                        {
                            minScore = distToMouse;
                            bestPoint = new TracePoint {
                                ScreenX = px, 
                                ScreenY = py, 
                                MathX = mX1, 
                                MathY = mY1,
                                Color = eq.Color, 
                                IsImportant = false, 
                                Label = ""
                            };
                        }
                    }
                }
            }
        }

        _activePoint = bestPoint;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        State.OnChange += async () => {
            if (_isReady) await RenderGraphsAsync();
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isReady = true;
            Viewport.CanvasWidth = 800; 
            Viewport.CanvasHeight = 600;
            await RenderGraphsAsync();
        }
    }

    private async Task RenderGraphsAsync()
    {
        if (!_isReady) return;

        var dims = await JSRuntime.InvokeAsync<double[]>("canvasRenderer.getDimensions", _canvasRef);
        Viewport.CanvasWidth = dims[0];
        Viewport.CanvasHeight = dims[1];

        await JSRuntime.InvokeVoidAsync("canvasRenderer.clear", _canvasRef);
        await JSRuntime.InvokeVoidAsync("canvasRenderer.drawAxes", _canvasRef, Viewport.CenterX, Viewport.CenterY, Viewport.UnitsPerPixel, Viewport.CanvasWidth, Viewport.CanvasHeight);

        var bounds = Viewport.GetVisibleMathBounds();
        double stepMathX = Viewport.UnitsPerPixel;

        foreach (var eq in State.Equations.Where(e => e.IsVisible && !e.HasError))
        {
            if (eq.IsPoint && eq.PointCoordinates.HasValue)
            {
                var (px, py) = Viewport.MathToScreen(eq.PointCoordinates.Value.X, eq.PointCoordinates.Value.Y);
                await JSRuntime.InvokeVoidAsync("canvasRenderer.drawPoint", _canvasRef, px, py, eq.Color);
            }
            else if (eq.IsImplicit && eq.Function != null)
            {
                int stepPx = (_isDragging || _isZooming) ? 16 : 4; // megaoptimized
                List<double> implicitSegments = new();

                for (double py = 0; py < Viewport.CanvasHeight; py += stepPx)
                {
                    for (double px = 0; px < Viewport.CanvasWidth; px += stepPx)
                    {
                        var (mX1, mY1) = Viewport.ScreenToMath(px, py);
                        var (mX2, mY2) = Viewport.ScreenToMath(px + stepPx, py);
                        var (mX3, mY3) = Viewport.ScreenToMath(px + stepPx, py + stepPx);
                        var (mX4, mY4) = Viewport.ScreenToMath(px, py + stepPx);

                        double v1 = eq.Function.Evaluate(mX1, mY1);
                        double v2 = eq.Function.Evaluate(mX2, mY2);
                        double v3 = eq.Function.Evaluate(mX3, mY3);
                        double v4 = eq.Function.Evaluate(mX4, mY4);

                        List<double> pts = new();

                        if (v1 * v2 <= 0 && v1 != v2) { double t = v1 / (v1 - v2); pts.Add(px + t * stepPx); pts.Add(py); }
                        if (v2 * v3 <= 0 && v2 != v3) { double t = v2 / (v2 - v3); pts.Add(px + stepPx); pts.Add(py + t * stepPx); }
                        if (v3 * v4 <= 0 && v3 != v4) { double t = v3 / (v3 - v4); pts.Add(px + (1-t) * stepPx); pts.Add(py + stepPx); }
                        if (v4 * v1 <= 0 && v4 != v1) { double t = v4 / (v4 - v1); pts.Add(px); pts.Add(py + (1-t) * stepPx); }

                        if (pts.Count >= 4) 
                        {
                            implicitSegments.Add(pts[0]); implicitSegments.Add(pts[1]);
                            implicitSegments.Add(pts[2]); implicitSegments.Add(pts[3]);
                        }
                    }
                }
                await JSRuntime.InvokeVoidAsync("canvasRenderer.drawImplicit", _canvasRef, implicitSegments.ToArray(), eq.Color);
            }
            else if (eq.Function != null)
            {
                int pointsCount = (int)((bounds.XMax - bounds.XMin) / stepMathX) + 1;
                if (pointsCount <= 0 || pointsCount > 10000) continue;

                double[] points = new double[pointsCount * 2];
                int index = 0;

                for (double mathX = bounds.XMin; mathX <= bounds.XMax; mathX += stepMathX)
                {
                    double mathY = eq.Function.Evaluate(mathX, 0);

                    if (double.IsNaN(mathY) || double.IsInfinity(mathY)) continue;

                    var (px, py) = Viewport.MathToScreen(mathX, mathY);
                    if (index < points.Length) 
                    { 
                    points[index++] = px; points[index++] = py; 
                    }
                }
                await JSRuntime.InvokeVoidAsync("canvasRenderer.drawGraph", _canvasRef, points.Take(index).ToArray(), eq.Color);
            }
        }
    }
}