@inject IJSRuntime JSRuntime

<canvas @ref="_canvasRef" width="800" height="600" style="border: 1px solid #ccc; background: white;"></canvas>

@code {
    private ElementReference _canvasRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Тестовый рендер параболы для проверки моста JS
            await TestRenderAsync();
        }
    }

    private async Task TestRenderAsync()
    {
        double[] points = new double[2000];
        int index = 0;
        for (int i = 0; i < 1000; i++)
        {
            double x = i;
            double y = (x - 400) * (x - 400) / 100 + 300; // Парабола
            points[index++] = x;
            points[index++] = y;
        }

        await JSRuntime.InvokeVoidAsync("canvasRenderer.drawGraph", _canvasRef, points);
    }
}