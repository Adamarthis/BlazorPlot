@page "/"
@using BlazorPlot.Web.Components
@using BlazorPlot.Web.Services
@inject CalculatorState State
@implements IDisposable

<div style="display: flex; height: 100vh; width: 100vw; overflow: hidden;">
    <div style="width: 350px; border-right: 1px solid #ddd; padding: 20px; display: flex; flex-direction: column;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <h3 style="margin: 0;">Formulas</h3>
            <button @onclick="State.AddEquation" style="background: #0078D7; color: white; border: none; padding: 5px 10px; border-radius: 4px;">+ Add</button>
        </div>

        <div style="flex: 1; overflow-y: auto;">
            @foreach (var eq in State.Equations)
            {
                <EquationItem @key="eq.Id" Equation="eq" />
            }
        </div>
    </div>

    <div style="flex: 1; display: flex; justify-content: center; align-items: center; background: #f3f3f3;">
        <CanvasArea />
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
        if (!State.Equations.Any()) State.AddEquation();
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}